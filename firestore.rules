rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Providers ─────────────────────────────────────────────────────────────
    // Public read (anyone can see provider listings).
    // Write only via backend service account (Firebase Admin SDK).
    match /providers/{providerId} {
      allow read: if true;
      allow write: if false; // backend-only via Admin SDK
    }

    // ── Bookings ──────────────────────────────────────────────────────────────
    // Authenticated users can read/write their own bookings.
    // Backend (Admin SDK) can always write.
    match /bookings/{bookingId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if false;
    }

    // ── Jobs (provider job dispatch) ──────────────────────────────────────────
    match /jobs/{jobId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Disputes ──────────────────────────────────────────────────────────────
    match /disputes/{disputeId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false; // immutable after creation
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    // Each user can only read/write their own profile.
    // Backend (Admin SDK) bypasses these rules entirely.
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Agent Logs ────────────────────────────────────────────────────────────
    match /agent_logs/{logId} {
      allow read: if request.auth != null;
      allow write: if false; // backend-only
    }

    // ── Deny everything else ──────────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
